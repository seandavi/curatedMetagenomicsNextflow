/*
 * Google Batch profile
 *
 * This profile keeps the cloud-specific retry rule for Batch interruption
 * semantics while inheriting the shared label-based resource policy.
 */

profiles {
    google {
        process.executor = 'google-batch'
        process.errorStrategy = { task.exitStatus == 14 || (task.exitStatus in 137..140 && task.attempt <= 3) ? 'retry' : 'terminate' }
        process.maxRetries = 3

        workDir = 'gs://cmgd-data/work'

        google.batch.bootDiskSize = '100.GB'
        google.batch.spot = true
        google.project = 'omicidx-338300'
    }
}
