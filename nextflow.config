/*
 * Top-level pipeline configuration
 *
 * This file intentionally focuses on:
 * - user-facing parameters
 * - pipeline metadata
 * - reporting / tracing defaults
 * - inclusion of reusable operational policy from conf/
 *
 * Resource sizing, retry policy, and executor-specific behavior are defined
 * in conf/base.config and conf/profiles/*.config so that the pipeline logic in
 * main.nf stays readable and site-specific changes are isolated.
 */

params {
    /*
     * Input selection
     *
     * Supported invocation patterns:
     * 1. metadata_tsv plus remote accessions
     * 2. metadata_tsv plus local_input=true and file_paths entries
     * 3. sample_id plus run_ids for a single sample run
     */
    metadata_tsv = null
    sample_id = null
    run_ids = null
    local_input = false

    /*
     * Shared storage for storeDir-backed database downloads.
     * Profiles can override this to use site-local persistent storage.
     */
    store_dir = 'databases'

    /*
     * KneadData parameters
     *
     * The workflow currently stages both database setup processes to preserve
     * the existing channel wiring. The selected reference remains controlled
     * by organism_database.
     */
    organism_database = 'human_genome' // Alternative: 'mouse_C57BL'

    /*
     * MetaPhlAn parameters
     *
     * Default is the current SGB database used by the pipeline. HUMAnN4
     * compatibility may require selecting the older index noted below.
     */
    metaphlan_index = 'mpa_vJan25_CHOCOPhlAnSGB_202503'
    // metaphlan_index = 'mpa_vOct22_CHOCOPhlAnSGB_202403' // required by humann4

    /*
     * HUMAnN parameters
     *
     * The HUMAnN branch is currently disabled by default because the active
     * MetaPhlAn index is newer than the version combination HUMAnN can consume
     * in this pipeline. Keep skip_humann=true unless the MetaPhlAn and HUMAnN
     * versions are intentionally realigned and validated together.
     */
    skip_humann = true
    chocophlan = 'full'
    uniref = 'uniref90_ec_filtered_diamond'

    /*
     * Publish behavior
     *
     * Published subdirectory names are part of the pipeline contract and
     * should not be changed casually because downstream users depend on them.
     */
    publish_mode = 'copy'
    cmgd_version = '4'
    publish_dir = "gs://cmgd-data/results/cMDv${params.cmgd_version}"
    // publish_dir = "/shares/CIBIO-Storage/CM/scratch/users/kaelyn.long/cmd_nf/local_out"
}

manifest {
    author = 'Sean Davis<seandavi@gmail.com>'
    defaultBranch = 'main'
    description = 'Curated Metagenomic Data pipeline'
    homePage = 'https://github.com/seandavi/curatedmetagenomicsnextflow'
    mainScript = 'main.nf'
    name = 'cmgd_nextflow'
    version = '1.5.0'
}

report {
    enabled = true
}

timeline {
    enabled = true
}

trace {
    enabled = true
    overwrite = true
    raw = true // Emit plain numeric values rather than humanized units.
    file = 'pipeline_trace.txt'
    fields = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,syscr,syscw,read_bytes,write_bytes,vol_ctxt,inv_ctxt,env,script,hostname,error_action'
}

weblog {
    enabled = true
    // Supply an override on the command line with -with-weblog if needed.
    url = 'https://nf-telemetry-819875667022.us-central1.run.app/nextflow-telemetry/events'
}

/*
 * Common runtime defaults
 */
singularity.enabled = true
singularity.pullTimeout = '2h'

includeConfig 'conf/base.config'
includeConfig 'conf/profiles/local.config'
includeConfig 'conf/profiles/anvil.config'
includeConfig 'conf/profiles/alpine.config'
includeConfig 'conf/profiles/google.config'
includeConfig 'conf/profiles/unitn.config'
