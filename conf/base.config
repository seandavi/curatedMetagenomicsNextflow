/*
 * Shared operational policy
 *
 * This file is the single place to tune:
 * - container defaults
 * - retry policy
 * - label-based resources
 * - resilience behavior such as memory growth across retries
 *
 * Labels are assigned in main.nf. Keep label names stable so users and site
 * operators can reason about resource classes without reading every process.
 */

process {
    container = 'docker://seandavi/curatedmetagenomics:metaphlan4.2.2'

    /*
     * Conservative default retry policy:
     * - retry common scheduler kill / OOM exit codes
     * - terminate on other failures unless a profile overrides behavior
     */
    errorStrategy = { (task.exitStatus in 137..140 && task.attempt <= 3) ? 'retry' : 'terminate' }
    maxRetries = 3

    /*
     * Labels capture intent rather than executor details.
     * This keeps main.nf readable and lets sites override classes centrally.
     */
    withLabel: 'qc' {
        cpus = 8
        memory = { 16.GB * task.attempt }
    }

    withLabel: 'io_heavy' {
        maxForks = 80
    }

    withLabel: 'host_filter' {
        cpus = 8
        memory = { 30.GB * task.attempt }
    }

    withLabel: 'profiling' {
        cpus = 16
        memory = { 30.GB + ((task.attempt - 1) * 8.GB) }
    }

    withLabel: 'functional_profile' {
        cpus = 16
        memory = { 48.GB + ((task.attempt - 1) * 16.GB) }
    }

    withLabel: 'db_setup' {
        cpus = 1
        memory = '4 GB'
    }

    withLabel: 'download_retry' {
        maxRetries = 4
    }

    withLabel: 'finalize' {
        cpus = 1
        memory = '2 GB'
    }

    /*
     * Process-specific overrides are kept here when a process meaningfully
     * differs from the general class defaults.
     */
    withName: 'install_metaphlan_db' {
        cpus = 4
        memory = { 8.GB * task.attempt }
    }

    withName: 'metaphlan_unknown_viruses_lists' {
        memory = { 47.GB + ((task.attempt - 1) * 8.GB) }
    }
}
