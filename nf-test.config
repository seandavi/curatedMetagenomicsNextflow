config {
    /*
     * Keep nf-test close to the repository defaults:
     * - tests live under tests/
     * - temporary state stays under .nf-test/
     * - use the local profile
     * - run without containers, telemetry, reports, or cloud publishing via
     *   the dedicated tests/nextflow.config include
     * - use stubs by default for fast structural coverage
     */
    testsDir "tests"
    workDir ".nf-test"
    configFile "tests/nextflow.config"
    profile "local"
    withTrace false
    autoSort true
    options "-stub-run"
    requires (
        "nf-test": "0.9.0"
    )
}
