/*
 * Local structural test overrides
 *
 * This file exists so developers can run `nextflow config` and `-stub-run`
 * validations in restricted environments without requiring outbound access for
 * telemetry, reporting integrations, or a local container runtime.
 */

weblog.enabled = false
report.enabled = false
timeline.enabled = false
trace.enabled = false

process.container = null
singularity.enabled = false

params.publish_base_dir = 'test-results'
params.publish_dir = null
