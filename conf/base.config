/*
 * Shared operational policy
 *
 * This file is the single place to tune:
 * - container defaults
 * - retry policy
 * - label-based resources
 * - resilience behavior such as memory growth across retries
 *
 * Labels are assigned in main.nf. Keep label names stable so users and site
 * operators can reason about resource classes without reading every process.
 */

process {
    container = 'docker://seandavi/curatedmetagenomics:metaphlan4.2.2'

    /*
     * Conservative default retry policy:
     * - retry common scheduler kill / OOM exit codes
     * - terminate on other failures unless a profile overrides behavior
     */
    errorStrategy = { (task.exitStatus in 137..140 && task.attempt <= 3) ? 'retry' : 'terminate' }
    maxRetries = 3

    /*
     * Labels are intentionally semantic. They communicate process class and
     * drive retry behavior, while exact baseline resources remain process-
     * specific below so the original sizing contract stays intact.
     */

    withLabel: 'download_retry' {
        maxRetries = 4
    }

    /*
     * Preserve the original CPU baselines from the pipeline implementation and
     * scale memory linearly by retry attempt:
     *
     *   effective_memory = baseline_memory * task.attempt
     *
     * This preserves first-attempt behavior while allowing retries to request
     * proportionally more memory after likely OOM or scheduler kill failures.
     */
    withName: 'fasterq_dump' {
        cpus = 8
        memory = { 16.GB * task.attempt }
    }

    withName: 'local_fastqc' {
        cpus = 8
        memory = { 16.GB * task.attempt }
    }

    withName: 'kneaddata' {
        cpus = 8
        memory = { 30.GB * task.attempt }
    }

    withName: 'install_metaphlan_db' {
        cpus = 4
        memory = { 8.GB * task.attempt }
    }

    withName: 'metaphlan_unknown_viruses_lists' {
        cpus = 16
        memory = { 47.GB * task.attempt }
    }

    withName: 'metaphlan_unknown_list' {
        cpus = 16
        memory = { 30.GB * task.attempt }
    }

    withName: 'metaphlan_markers' {
        cpus = 16
        memory = { 30.GB * task.attempt }
    }

    withName: 'sample_to_markers' {
        cpus = 16
        memory = { 32.GB * task.attempt }
    }

    withName: 'chocophlan_db' {
        cpus = 1
        memory = { 1.GB * task.attempt }
    }

    withName: 'utility_mapping_db' {
        cpus = 1
        memory = { 1.GB * task.attempt }
    }

    withName: 'uniref_db' {
        cpus = 1
        memory = { 1.GB * task.attempt }
    }

    withName: 'kneaddata_human_database' {
        cpus = 1
        memory = { 4.GB * task.attempt }
    }

    withName: 'kneaddata_mouse_database' {
        cpus = 1
        memory = { 4.GB * task.attempt }
    }

    withName: 'humann' {
        cpus = 16
        memory = { 48.GB * task.attempt }
    }

    withName: 'MARK_COMPLETE' {
        cpus = 1
        memory = { 2.GB * task.attempt }
    }

}
