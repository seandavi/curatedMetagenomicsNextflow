/*
 * Dev profile
 *
 * Points the pipeline at a telemetry server running locally on the
 * developer's workstation (uvicorn on :8000). Both params.api_url and
 * weblog.url are re-set together so the per-task afterScript upload and
 * the weblog event stream both reach the same server.
 *
 * Combine with site profiles as needed, e.g.:
 *   nextflow run ... -profile alpine,dev
 */

profiles {
    dev {
        params.api_url = 'http://localhost:8000/api'
        weblog.url     = 'http://localhost:8000/telemetry'
    }
}
