/*
 * Rollback profile
 *
 * Emergency fallback that points the pipeline back at the legacy Cloud
 * Run telemetry endpoint (the GCP-issued *.run.app URL). Use only during
 * the onclappc02 migration window if the new self-hosted stack hiccups
 * before Cloud Run is decommissioned.
 *
 * Removable once seandavi/nextflow_telemetry#82 (Phase 4 teardown of
 * Cloud Run + Cloud SQL) is complete — the legacy URL stops resolving
 * at that point and this profile loses its meaning.
 *
 * Combine with site profiles as needed, e.g.:
 *   nextflow run ... -profile alpine,rollback
 */

profiles {
    rollback {
        params.api_url = 'https://nf-telemetry-819875667022.us-central1.run.app/api'
        weblog.url     = 'https://nf-telemetry-819875667022.us-central1.run.app/telemetry'
    }
}
